# Copie ce fichier en .env et renseigne tes clés.

# Chat texte — clé Google Gemini : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Générateur de memes — Cloudflare Workers AI (FLUX.2-dev, gratuit).
# Account ID : dashboard Cloudflare. Token : My Profile > API Tokens, permission "Workers AI".
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# (Optionnel) Fournies automatiquement par Replit — laisser vide hors Replit.
# AI_INTEGRATIONS_GEMINI_API_KEY=
# AI_INTEGRATIONS_GEMINI_BASE_URL=
